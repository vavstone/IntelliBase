# Корневой Settings
APP_NAME=llm-service-example
DEBUG=false
CORS_ORIGINS=["http://localhost:3000"]
REDIS_URL=redis://localhost:6379/0
CACHE_TTL_SECONDS=3600
# заполнить при использовании proxy, иначе оставить пустым
PROXY_URL=http://user:pass@ip:8888

# LLMSettings (env_prefix="LLM_", nested через "__")
LLM__OPENAI_API_KEY=...
LLM__DEFAULT_MODEL=gpt-4o-mini
LLM__REQUEST_TIMEOUT=30.0
LLM__MAX_RETRIES=3